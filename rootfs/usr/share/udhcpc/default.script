#!/bin/sh
case "$1" in
	bound|renew)
		ifconfig "$interface" "$ip" netmask "$subnet" broadcast "$broadcast"
		[ -n "$router" ] && route add default gw "$router" dev "$interface" 2>/dev/null
		[ -n "$dns" ] && echo "nameserver $dns" > /etc/resolv.conf 2>/dev/null
		;;
	deconfig)
		ifconfig "$interface" 0.0.0.0
		;;
	leasefail|nak)
		exit 1
		;;
esac
