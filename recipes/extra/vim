name=vim
version=9.1.1087
source=https://github.com/vim/vim/archive/refs/tags/v9.1.1087.tar.gz
build() {
    cd "$WAV_SRC"
    ./configure --prefix=/usr --sysconfdir=/etc --with-features=tiny --disable-gui --without-x --disable-gpm
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
    ln -sf vim "$WAV_SYSROOT/usr/bin/vi" 2>/dev/null || true
}