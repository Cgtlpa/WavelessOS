name=fastfetch
version=2.65.2
source=https://github.com/fastfetch-cli/fastfetch/archive/refs/tags/2.65.2.tar.gz
build() {
    mkdir -p "$WAV_BUILD_DIR"/build
    cd "$WAV_BUILD_DIR"/build
    cmake "$WAV_SRC" \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DENABLE_SYSTEM_YYJSON=OFF
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_BUILD_DIR"/build
    make DESTDIR="$WAV_SYSROOT" install
}