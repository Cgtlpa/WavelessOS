name=xfce4-notifyd
version=0.9.6
source=https://archive.xfce.org/src/apps/xfce4-notifyd/0.9/xfce4-notifyd-0.9.6.tar.bz2
depends=(libxfce4ui gtk3)
build() {
    cd "$WAV_SRC"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static \
        --enable-shared
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
}