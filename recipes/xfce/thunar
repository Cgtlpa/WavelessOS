name=thunar
version=4.18.11
source=https://archive.xfce.org/src/xfce/thunar/4.18/thunar-4.18.11.tar.bz2
depends=(libxfce4ui xfconf gtk3 libexif)
build() {
    cd "$WAV_SRC"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static \
        --enable-shared
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
}