name=xfce4-power-manager
version=4.18.1
source=https://archive.xfce.org/src/xfce/xfce4-power-manager/4.18/xfce4-power-manager-4.18.1.tar.bz2
depends=(libxfce4ui xfconf upower polkit)
build() {
    cd "$WAV_SRC"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static \
        --enable-shared
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
}