name=garcon
version=4.18.1
source=https://archive.xfce.org/src/xfce/garcon/4.18/garcon-4.18.1.tar.bz2
depends=(libxfce4util gtk3)
build() {
    cd "$WAV_SRC"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static \
        --enable-shared
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
}