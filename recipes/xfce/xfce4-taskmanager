name=xfce4-taskmanager
version=1.5.7
source=https://archive.xfce.org/src/apps/xfce4-taskmanager/1.5/xfce4-taskmanager-1.5.7.tar.bz2
depends=(libxfce4ui gtk3)
build() {
    cd "$WAV_SRC"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static \
        --enable-shared
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
}