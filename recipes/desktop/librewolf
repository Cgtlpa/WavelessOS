name=librewolf
version=152.0.4-1
source=https://codeberg.org/librewolf/source/archive/152.0.4-1.tar.gz
depends=(gtk3 dbus xorg-server pulseaudio alsa-lib fontconfig freetype libXt nss)
build() {
    cd "$WAV_SRC"
    ./mach configure --prefix="$WAV_SYSROOT" --disable-crashreporter --disable-updater
    ./mach build -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    ./mach install
    mkdir -p "$WAV_SYSROOT/usr/bin" "$WAV_SYSROOT/usr/share/applications"
    ln -sf "$WAV_SYSROOT/opt/librewolf/librewolf" "$WAV_SYSROOT/usr/bin/librewolf"
    cat > "$WAV_SYSROOT/usr/share/applications/librewolf.desktop" << EOF
[Desktop Entry]
Name=LibreWolf
Exec=librewolf %u
Icon=librewolf
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;x-scheme-handler/http;x-scheme-handler/https;
EOF
}
