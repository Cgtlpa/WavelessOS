name=hyprland
version=0.46.2
source=https://github.com/hyprwm/Hyprland/releases/download/v0.46.2/source-v0.46.2.tar.gz
depends=(wayland libinput mesa xwayland seatd)
build() {
    mkdir -p "$WAV_BUILD_DIR"/build
    cd "$WAV_BUILD_DIR"/build
    meson setup "$WAV_SRC" \
        --prefix=/usr \
        --sysconfdir=/etc \
        --buildtype=release
    ninja -j"$WAV_JOBS"
}
install() {
    cd "$WAV_BUILD_DIR"/build
    DESTDIR="$WAV_SYSROOT" ninja install
}