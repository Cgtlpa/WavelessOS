name=pavucontrol
version=6.1
source=https://freedesktop.org/software/pulseaudio/pavucontrol/pavucontrol-6.1.tar.gz
depends=(pulseaudio gtk3 libcanberra)
build() {
    cd "$WAV_SRC"
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc \
        --localstatedir=/var \
        --disable-static \
        --enable-shared
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_SRC"
    make DESTDIR="$WAV_SYSROOT" install
}
