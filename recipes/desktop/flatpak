name=flatpak
version=1.15.12
source=https://github.com/flatpak/flatpak/releases/download/1.15.12/flatpak-1.15.12.tar.xz
depends=(glib fuse3 polkit xdg-dbus-proxy bubblewrap)
build() {
    mkdir -p "$WAV_BUILD_DIR"/build
    cd "$WAV_BUILD_DIR"/build
    cmake "$WAV_SRC" \
        -DCMAKE_INSTALL_PREFIX="$WAV_SYSROOT/usr" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_SYSCONFDIR="$WAV_SYSROOT/etc"
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_BUILD_DIR"/build
    make DESTDIR="$WAV_SYSROOT" install
}