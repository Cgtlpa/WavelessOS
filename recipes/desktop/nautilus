name=nautilus
version=47.4
source=https://download.gnome.org/sources/nautilus/47/nautilus-47.4.tar.xz
depends=(gtk4 glib libadwaita tracker)
build() {
    mkdir -p "$WAV_BUILD_DIR"/build
    cd "$WAV_BUILD_DIR"/build
    cmake "$WAV_SRC" \
        -DCMAKE_INSTALL_PREFIX="$WAV_SYSROOT/usr" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_SYSCONFDIR="$WAV_SYSROOT/etc"
    make -j"$WAV_JOBS"
}
install() {
    cd "$WAV_BUILD_DIR"/build
    DESTDIR="$WAV_SYSROOT" make install
}